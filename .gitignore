# ============================================================
# CodeBuddy2API .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.Python
build/
dist/
eggs/
.eggs/
sdist/
var/
wheels/
MANIFEST

# --- Virtual Environments ---
.env
venv/
venv2/
.venv/
env/
ENV/

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
._*

# ============================================================
# Project-Specific
# ============================================================

# --- Credentials & API Keys (NEVER commit) ---
kiro_keys.json
harvested_keys.json
harvested_credentials.txt
accounts.txt
accounts_batch*.txt
.codebuddy_creds/
!.codebuddy_creds/.gitkeep

# --- Runtime Data ---
stats.json
harvest_log.txt
has_credit.txt
no_credit.txt
error_credit.txt
data/
logs/
*.log
.sessions/
.mcp_data/

# --- Config (local only) ---
config.json
config/config.json

# --- Debug / Temp ---
*.har
*.tmp
*.temp
*.bak
*.backup
tmp_*
temp_*

# --- Archive (local cleanup, not for git) ---
_archive/

# --- OpenCode Config (personal, not part of project) ---

# --- Misc ---
.opencode-context.md
KIRO_AUTH_FIX.md
.claude/settings.local.json
